<div class="news">
  {% assign current_locale = page.locale | default: site.lang | default: 'en' %}
  {% assign locale_strings = site.data.i18n[current_locale] %}
  {% assign date_format = locale_strings.date_format | default: '%b %d, %Y' %}
  {% assign locale_news = site.news | where: 'locale', current_locale %}
  {% if locale_news != blank %}
    {% assign news_size = locale_news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = locale_news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: date_format }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>{{ locale_strings.no_news }}</p>
  {% endif %}
</div>
